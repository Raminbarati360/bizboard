{
  "tools": [
    {
      "name": "search_products",
      "description": "Search products using text, category, budget, attributes and availability filters.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "category_slug": {
            "type": "string"
          },
          "min_price": {
            "type": "number"
          },
          "max_price": {
            "type": "number"
          },
          "must_be_in_stock": {
            "type": "boolean"
          },
          "attributes": {
            "type": "object"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          }
        },
        "required": [
          "query"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array"
          },
          "filters_used": {
            "type": "object"
          },
          "data_freshness_note": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "compare_products",
      "description": "Compare two to five products by specs, offers, reviews and suitability.",
      "input_schema": {
        "type": "object",
        "properties": {
          "product_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 5
          },
          "user_priorities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "product_ids"
        ]
      }
    },
    {
      "name": "get_product_offers",
      "description": "Get current offers for a product, sorted by relevance/trust/price.",
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "only_in_stock": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          }
        },
        "required": [
          "product_id"
        ]
      }
    },
    {
      "name": "get_business_profile",
      "description": "Get mini-site profile, trust signals and contact info of a business.",
      "input_schema": {
        "type": "object",
        "properties": {
          "business_id": {
            "type": "string"
          }
        },
        "required": [
          "business_id"
        ]
      }
    },
    {
      "name": "start_checkout",
      "description": "Start checkout only for offers with internal_checkout_enabled=true.",
      "input_schema": {
        "type": "object",
        "properties": {
          "offer_id": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "offer_id",
          "quantity"
        ]
      }
    },
    {
      "name": "track_outbound_click",
      "description": "Track click to merchant website while respecting sponsored/organic labeling.",
      "input_schema": {
        "type": "object",
        "properties": {
          "offer_id": {
            "type": "string"
          },
          "placement": {
            "type": "string"
          },
          "is_sponsored": {
            "type": "boolean"
          }
        },
        "required": [
          "offer_id",
          "placement"
        ]
      }
    }
  ]
}
