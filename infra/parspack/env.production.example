# Bizboard ParsPack PaaS staging env
# این فایل template است. مقدار واقعی secretها را فقط در پنل PaaS / Config/Secret وارد کنید.

NODE_ENV=production

# CI must publish images with this namespace, for example:
# ghcr.io/YOUR_ORG/bizboard/web:staging
IMAGE_REGISTRY=ghcr.io/YOUR_ORG/bizboard
IMAGE_TAG=staging

# Public URLs configured in ParsPack PaaS domain settings
NEXT_PUBLIC_WEB_URL=https://staging.bizboard.co
NEXT_PUBLIC_API_URL=https://api-staging.bizboard.co/api/v1
NEXT_PUBLIC_ADMIN_URL=https://admin-staging.bizboard.co
API_CORS_ORIGINS=https://staging.bizboard.co,https://admin-staging.bizboard.co

# Internal service URLs inside Docker Compose network
POSTGRES_DB=bizboard
POSTGRES_USER=bizboard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://bizboard:CHANGE_ME_STRONG_PASSWORD@postgres:5432/bizboard
REDIS_URL=redis://redis:6379

# Sprint 0 convenience: API runs migrations/seed on startup.
# After staging is stable, set this to false and run migrations as a controlled release step.
RUN_MIGRATIONS_ON_START=true

JWT_ACCESS_SECRET=CHANGE_ME_MINIMUM_32_CHARS_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_32_CHARS_REFRESH

# AI Provider Gateway - default: GapGPT
AI_DEFAULT_PROVIDER=gapgpt
AI_DEFAULT_CHAT_MODEL=gpt-4o-mini
AI_DEFAULT_EMBEDDING_PROVIDER=gapgpt
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
AI_ALLOW_PROVIDER_FALLBACK=false
AI_LOG_PROMPTS=true
AI_LOG_RESPONSES=false
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2

GAPGPT_API_KEY=
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_CHAT_MODEL=gpt-4o-mini
GAPGPT_EMBEDDING_MODEL=text-embedding-3-small

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ParsPack S3-compatible Object Storage
S3_ENDPOINT=
S3_REGION=default
S3_BUCKET=bizboard-staging
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

SENTRY_DSN=
PAYMENT_GATEWAY_MODE=mock
PAYMENT_CALLBACK_BASE_URL=https://api-staging.bizboard.co/api/v1/payments/callback
ZARINPAL_MERCHANT_ID=
ZIBAL_MERCHANT_ID=

WORKER_CONCURRENCY=5
CRAWLER_CONCURRENCY=2
CRAWLER_USER_AGENT=BizboardBot/0.1 (+https://staging.bizboard.co/bot)
CRAWLER_RESPECT_ROBOTS=true
