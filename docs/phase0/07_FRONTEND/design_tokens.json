{
  "direction": "rtl",
  "font": {
    "primary": "Vazirmatn or Estedad - use licensed package/CDN, do not commit font files unless license allows",
    "fallback": "Tahoma, Arial, sans-serif"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px"
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px"
  },
  "shadow": {
    "card": "0 8px 24px rgba(15, 23, 42, 0.08)",
    "floating": "0 16px 48px rgba(15, 23, 42, 0.14)"
  },
  "components": {
    "button": [
      "primary",
      "secondary",
      "ghost",
      "danger",
      "sponsored"
    ],
    "card": [
      "product",
      "business",
      "merchant",
      "seoBlock",
      "adminMetric"
    ],
    "states": [
      "loading",
      "empty",
      "error",
      "success",
      "skeleton"
    ]
  }
