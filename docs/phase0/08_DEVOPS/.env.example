# App
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:3001/api/v1

# Database
DATABASE_URL=postgresql://bizboard:bizboard_dev_password@localhost:5432/bizboard

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
OTP_SECRET=change_me_otp_secret

# Storage S3-Compatible
S3_ENDPOINT=https://s3.example.com
S3_REGION=ir
S3_BUCKET=bizboard-dev
S3_ACCESS_KEY_ID=change_me
S3_SECRET_ACCESS_KEY=change_me
S3_PUBLIC_BASE_URL=https://cdn.example.com

# AI
OPENAI_API_KEY=change_me
AI_DEFAULT_MODEL=gpt-5.5-thinking
AI_EMBEDDING_MODEL=text-embedding-3-large

# Payments
ZARINPAL_MERCHANT_ID=change_me
ZARINPAL_CALLBACK_URL=http://localhost:3001/api/v1/payments/callback/zarinpal
ZIBAL_MERCHANT_ID=change_me
ZIBAL_CALLBACK_URL=http://localhost:3001/api/v1/payments/callback/zibal

# SMS/Email
SMS_PROVIDER=mock
SMS_API_KEY=change_me
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ADMIN_2FA_REQUIRED=false

# Crawler
CRAWLER_USER_AGENT=BizboardBot/0.1 (+https://bizboard.co/bot)
CRAWLER_DEFAULT_RATE_LIMIT_PER_DOMAIN=1
CRAWLER_RESPECT_ROBOTS=true
